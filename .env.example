# =========================================================
# Environment Variables — Multimodal AI Shopping Assistant
# =========================================================
# Fill in your real keys below. NEVER commit this file with
# real credentials to a public repository. Add ".env" to .gitignore.

# Google Gemini API key (used for Gemini Vision + Gemini Flash)
# Get it from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API key (real-time web search for prices/specs/reviews)
# Get it from: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: SerpAPI key, used as a fallback/alternate search provider
# Get it from: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_api_key_here

# Gemini model names (kept configurable so you can swap versions easily)
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_TEXT_MODEL=gemini-2.0-flash

# App-level settings
APP_ENV=development
MAX_SEARCH_RESULTS=8
